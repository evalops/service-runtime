#!/usr/bin/env bash
set -e

# Run lint on staged Go files only
STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
if [ -n "$STAGED" ]; then
  STASHED=0
  if ! git diff --quiet || [ -n "$(git ls-files --others --exclude-standard)" ]; then
    git stash push --keep-index --include-untracked -q
    STASHED=1
    trap 'status=$?; if [ "$STASHED" -eq 1 ]; then git stash pop -q; fi; exit "$status"' EXIT
  fi

  echo "Running golangci-lint on staged files..."
  golangci-lint run --new-from-rev=HEAD ./...
  echo "Running go test..."
  go test -race ./...
fi
